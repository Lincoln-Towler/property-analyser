# Public reads (RLS makes the anon key read-only once migration 0004 is applied)
NEXT_PUBLIC_SUPABASE_URL=https://uorrpukzqwyvzbewgudk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (Vercel env vars, never NEXT_PUBLIC): used by /api/snapshot to
# write the daily score row. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret so only Vercel Cron can trigger the snapshot
CRON_SECRET=generate-a-random-string
